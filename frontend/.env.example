# Frontend Environment Configuration
# Copy this file to .env and update with your actual values

# ==================== BIGBLUEBUTTON (BBB) CONFIGURATION ====================
# IMPORTANT: These BBB settings are for UI/display purposes only
# The actual BBB server URL and join links come from the backend API
# Configure your real BBB server in backend/.env instead
#
# NOTE: Frontend only needs BBB_EMAIL for display purposes
# All session join URLs are generated by backend API: /api/bbb/sessions/{id}/join/
BBB_EMAIL=bbb@entailabs.com
BBB_ENABLED=true
BBB_MAX_PARTICIPANTS=100
BBB_RECORD_BY_DEFAULT=true

# ==================== BACKEND API ====================
API_BASE_URL=http://localhost:8000

# ==================== INSTRUCTIONS ====================
# To use these environment variables in Flutter:
#
# Option 1: Using flutter run with --dart-define
# flutter run --dart-define=BBB_EMAIL=bbb@entailabs.com \
#            --dart-define=API_BASE_URL=http://localhost:8000
#
# Option 2: Create a .env file and use flutter_dotenv package
# (Recommended for development)
#
# Option 3: Use build arguments in your build configuration
# See: https://docs.flutter.dev/deployment/flavors
#
# IMPORTANT: BBB sessions now work via backend API
# - Frontend fetches join URLs from: GET /api/bbb/sessions/{id}/join/
# - Configure your actual BBB server in backend/.env
# - BBB sessions appear as modal overlay popups (not full page navigation)
